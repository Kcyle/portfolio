---
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Kyle Goh Portfolio</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Campton:wght@400;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
    <style>
      :root {
        --nu-purple: #4E2A84;
        --nu-purple-light: #836EAA;
        --nu-purple-dark: #371F5E;
        --nu-white: #FFFFFF;
        --bar-height: 54px;
      }

      * { margin: 0; padding: 0; box-sizing: border-box; }
      html, body { width: 100%; height: 100%; overflow: hidden; font-family: 'Inter', sans-serif; }

      .topbar {
        height: var(--bar-height);
        background: var(--nu-purple);
        display: flex;
        align-items: center;
        padding: 0 20px;
        gap: 8px;
        position: relative;
        z-index: 10;
        box-shadow: 0 2px 8px rgba(0,0,0,0.25);
      }

      .topbar__brand {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-right: 24px;
        white-space: nowrap;
      }

      .topbar__name {
        color: var(--nu-white);
        font-size: 15px;
        font-weight: 600;
        letter-spacing: 0.02em;
      }

      .topbar__label {
        color: var(--nu-purple-light);
        font-size: 11px;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.08em;
      }

      .topbar__tabs {
        display: flex;
        gap: 2px;
        height: 100%;
        align-items: stretch;
        overflow-x: auto;
        -ms-overflow-style: none;
        scrollbar-width: none;
      }
      .topbar__tabs::-webkit-scrollbar { display: none; }

      .tab {
        display: flex;
        align-items: center;
        padding: 0 16px;
        color: rgba(255,255,255,0.7);
        font-size: 13px;
        font-weight: 500;
        cursor: pointer;
        border: none;
        background: none;
        white-space: nowrap;
        transition: all 0.2s;
        border-bottom: 2px solid transparent;
        font-family: inherit;
      }
      .tab:hover {
        color: var(--nu-white);
        background: rgba(255,255,255,0.08);
      }
      .tab.active {
        color: var(--nu-white);
        border-bottom-color: var(--nu-white);
        background: rgba(255,255,255,0.1);
      }


      .topbar__spacer { flex: 1; }

      .topbar__nw {
        color: rgba(255,255,255,0.45);
        font-size: 11px;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        white-space: nowrap;
      }

      .viewer {
        width: 100%;
        height: calc(100% - var(--bar-height));
        position: relative;
        background: #0a0a0a;
      }

      .viewer__frame {
        width: 100%;
        height: 100%;
        border: none;
        display: none;
      }
      .viewer__frame.active { display: block; }

      .viewer__embed {
        width: 100%;
        height: 100%;
        display: none;
        align-items: center;
        justify-content: center;
        background: #0a0a0a;
        flex-direction: column;
      }
      .viewer__embed.active { display: flex; }

      .viewer__embed iframe {
        width: 100%;
        height: 100%;
        border: none;
      }

      .viewer__slideshow {
        width: 100%;
        height: 100%;
        display: none;
        align-items: center;
        justify-content: center;
        background: #0a0a0a;
        position: relative;
      }
      .viewer__slideshow.active { display: flex; }

      .viewer__slideshow img {
        max-width: 90%;
        max-height: 90%;
        object-fit: contain;
        position: absolute;
        opacity: 0;
        transition: opacity 0.6s;
        border-radius: 8px;
        box-shadow: 0 4px 30px rgba(0,0,0,0.5);
      }
      .viewer__slideshow img.show { opacity: 1; }


      .viewer__render {
        width: 100%;
        height: 100%;
        display: none;
        position: relative;
        background: #000;
      }
      .viewer__render.active { display: block; }

      .render__canvas {
        position: absolute;
        top: 0; left: 0;
        width: 100%;
        height: 100%;
        display: block;
      }

      .render__build, .render__community {
        position: absolute;
        top: 15%;
        right: 12%;
        z-index: 1;
        pointer-events: none;
        text-align: right;
        opacity: 0;
      }

      .render__build-title, .render__community-title {
        font-family: 'Inter', sans-serif;
        font-size: 5vw;
        font-weight: 900;
        letter-spacing: -0.03em;
        text-transform: uppercase;
        color: #fff;
      }

      .render__build-sub, .render__community-sub {
        font-family: 'Inter', sans-serif;
        font-size: 1vw;
        font-weight: 400;
        color: rgba(255, 255, 255, 0.6);
        margin-top: 0.3em;
      }

      @media (max-width: 768px) {
        .render__build, .render__community { top: 12%; right: 8%; }
        .render__build-title, .render__community-title { font-size: 28px; }
        .render__build-sub, .render__community-sub { font-size: 12px; }
      }

      @media (max-width: 700px) {
        .topbar__nw { display: none; }
        .topbar__label { display: none; }
        .tab { padding: 0 10px; font-size: 12px; }
      }
    </style>
  </head>
  <body>
    <nav class="topbar">
      <div class="topbar__brand">
        <div>
          <div class="topbar__name">Kyle Goh</div>
          <div class="topbar__label">Portfolio</div>
        </div>
      </div>

      <div class="topbar__tabs">
        <button class="tab active" data-tab="xr">
          xr.umd.edu
        </button>
        <button class="tab" data-tab="tas">
          tas.umd.edu
        </button>
        <button class="tab" data-tab="render">
          AE Render
        </button>
        <button class="tab" data-tab="nycto">
          Nyctophobia VR
        </button>
        <button class="tab" data-tab="testudo">
          Horror Game
        </button>
        <button class="tab" data-tab="animator">
          Animator VR
        </button>
      </div>

      <span class="topbar__spacer"></span>
      <span class="topbar__nw">Go 'Cats!</span>
    </nav>

    <div class="viewer">
      <!-- Live sites -->
      <iframe class="viewer__frame active" id="view-xr" src="https://xr.umd.edu/"></iframe>
      <iframe class="viewer__frame" id="view-tas" src="about:blank" data-src="https://tas.umd.edu/"></iframe>

      <!-- Render -->
      <div class="viewer__render" id="view-render">
        <canvas class="render__canvas" data-render-canvas></canvas>
        <div class="render__build" data-render-build>
          <h2 class="render__build-title">Build Anything</h2>
          <p class="render__build-sub">(This scene was built in Blender)</p>
        </div>
        <div class="render__community" data-render-community>
          <h2 class="render__community-title">Build Together</h2>
          <p class="render__community-sub">(Built entirely using one of our corporate sponsors exclusive software)</p>
        </div>
      </div>

      <!-- Video embeds -->
      <div class="viewer__embed" id="view-nycto">
        <iframe src="about:blank" data-src="https://www.youtube.com/embed/ewcoaFnz-mk?autoplay=1" allow="autoplay; encrypted-media" allowfullscreen></iframe>
      </div>

      <div class="viewer__embed" id="view-animator">
        <iframe src="about:blank" data-src="https://www.youtube.com/embed/gnKMSc9yxlk?autoplay=1" allow="autoplay; encrypted-media" allowfullscreen></iframe>
      </div>

      <!-- Slideshow -->
      <div class="viewer__slideshow" id="view-testudo">
        <img src="/images/Scene1.PNG" alt="Scene 1" class="show" />
        <img src="/images/scene2.PNG" alt="Scene 2" />
        <img src="/images/scene3.PNG" alt="Scene 3" />
        <img src="/images/scene4.PNG" alt="Scene 4" />
        <img src="/images/scene5.PNG" alt="Scene 5" />
        <img src="/images/scene6.PNG" alt="Scene 6" />
        <img src="/images/scene7.PNG" alt="Scene 7" />
        <img src="/images/scene8.PNG" alt="Scene 8" />
        <img src="/images/scene9.PNG" alt="Scene 9" />
        <img src="/images/scene10.PNG" alt="Scene 10" />
        <img src="/images/scene11.PNG" alt="Scene 11" />
      </div>
    </div>

    <script>
      // Track visitor
      (async () => {
        try {
          const geo = await fetch('https://ipapi.co/json/').then(r => r.json());
          await fetch('https://cpgkqtldivzjmzxqcsvf.supabase.co/rest/v1/visitors', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              'apikey': 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImNwZ2txdGxkaXZ6am16eHFjc3ZmIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzEzODk1NzQsImV4cCI6MjA4Njk2NTU3NH0.0C1IDzqqcOQIRl-L1i-Q9PJkCgnOdos_XJr1J4cvCwY',
            },
            body: JSON.stringify({
              ip: geo.ip,
              city: geo.city,
              region: geo.region,
              country: geo.country_name,
              loc: `${geo.latitude},${geo.longitude}`,
              user_agent: navigator.userAgent,
            }),
          });
        } catch {}
      })();

      import { initRenderCanvas } from '../animations/scroll';
      import type { FrameTrigger } from '../animations/scroll';

      const tabs = document.querySelectorAll<HTMLButtonElement>('.tab');
      const allPanels = document.querySelectorAll('.viewer__frame, .viewer__embed, .viewer__slideshow, .viewer__render');

      tabs.forEach(tab => {
        tab.addEventListener('click', () => {
          const id = tab.dataset.tab!;

          // Update tabs
          tabs.forEach(t => t.classList.remove('active'));
          tab.classList.add('active');

          // Hide all panels
          allPanels.forEach(p => p.classList.remove('active'));

          // Show target
          const target = document.getElementById(`view-${id}`)!;
          target.classList.add('active');

          // Lazy-load iframes
          if (target.tagName === 'IFRAME') {
            const frame = target as HTMLIFrameElement;
            if (frame.dataset.src && frame.src === 'about:blank') {
              frame.src = frame.dataset.src;
            }
          }
          // Also handle nested iframes in embed panels
          const nested = target.querySelector('iframe[data-src]') as HTMLIFrameElement | null;
          if (nested && nested.src === 'about:blank') {
            nested.src = nested.dataset.src!;
          }

          // Stop and unload YouTube videos in hidden panels
          allPanels.forEach(p => {
            if (p !== target) {
              const vid = p.querySelector('iframe[data-src]') as HTMLIFrameElement | null;
              if (vid && vid.src !== 'about:blank') {
                vid.src = 'about:blank';
              }
            }
          });
        });
      });

      // Slideshow
      const slideshow = document.getElementById('view-testudo')!;
      const slides = slideshow.querySelectorAll('img');
      let current = 0;
      setInterval(() => {
        slides[current].classList.remove('show');
        current = (current + 1) % slides.length;
        slides[current].classList.add('show');
      }, 3000);

      // Render canvas
      const renderCanvas = document.querySelector('[data-render-canvas]') as HTMLCanvasElement;
      const renderBuild = document.querySelector('[data-render-build]') as HTMLElement;
      const renderCommunity = document.querySelector('[data-render-community]') as HTMLElement;

      const frameTriggers: FrameTrigger[] = [];
      const audioQueue: HTMLAudioElement[] = [];
      let bootupRef: HTMLAudioElement | null = null;
      let scifiRef: HTMLAudioElement | null = null;

      // Glitch sound at specific frames
      for (const f of [160, 256, 413, 568, 653, 817]) {
        frameTriggers.push({ frame: f, fired: false, callback: () => {
          const glitch = new Audio('/glitch.mp3');
          audioQueue.push(glitch);
          glitch.play().catch(() => {});
        }});
      }

      if (renderBuild) {
        frameTriggers.push({ frame: 435, fired: false, callback: () => { renderBuild.style.transition = 'opacity 0.5s ease'; renderBuild.style.opacity = '1'; } });
        frameTriggers.push({ frame: 569, fired: false, callback: () => { renderBuild.style.transition = 'opacity 0.4s ease'; renderBuild.style.opacity = '0'; } });
      }
      if (renderCommunity) {
        frameTriggers.push({ frame: 704, fired: false, callback: () => { renderCommunity.style.transition = 'opacity 0.5s ease'; renderCommunity.style.opacity = '1'; } });
        frameTriggers.push({ frame: 810, fired: false, callback: () => { renderCommunity.style.transition = 'opacity 0.4s ease'; renderCommunity.style.opacity = '0'; } });
      }

      frameTriggers.push({ frame: 1, fired: false, callback: () => {
        const bootup = new Audio('/bootup.mp3');
        audioQueue.push(bootup); bootupRef = bootup;
        bootup.play().catch(() => {});
      }});

      frameTriggers.push({ frame: 150, fired: false, callback: () => {
        if (!bootupRef) return;
        const fade = setInterval(() => {
          if (!bootupRef || bootupRef.volume <= 0.05) { if (bootupRef) { bootupRef.pause(); bootupRef.currentTime = 0; bootupRef = null; } clearInterval(fade); return; }
          bootupRef.volume = Math.max(0, bootupRef.volume - 0.1);
        }, 30);
      }});

      frameTriggers.push({ frame: 160, fired: false, callback: () => {
        if (bootupRef) { bootupRef.pause(); bootupRef.currentTime = 0; bootupRef = null; }
        const immersed = new Audio('/immersed.mp3');
        audioQueue.push(immersed);
        immersed.play().catch(() => {});
      }});

      frameTriggers.push({ frame: 200, fired: false, callback: () => {
        const scifi = new Audio('/scifi.mp3');
        scifi.currentTime = Math.max(0, 36 - (435 - 200) / 30);
        scifi.volume = 0;
        audioQueue.push(scifi); scifiRef = scifi;
        scifi.play().catch(() => {});
        const fadeIn = setInterval(() => {
          if (!scifiRef || scifiRef.volume >= 0.95) { if (scifiRef) scifiRef.volume = 1; clearInterval(fadeIn); return; }
          scifiRef.volume = Math.min(1, scifiRef.volume + 0.05);
        }, 80);
      }});

      frameTriggers.push({ frame: 800, fired: false, callback: () => {
        if (!scifiRef) return;
        const fadeOut = setInterval(() => {
          if (!scifiRef || scifiRef.volume <= 0.02) { if (scifiRef) { scifiRef.pause(); scifiRef.currentTime = 0; } clearInterval(fadeOut); return; }
          scifiRef.volume = Math.max(0, scifiRef.volume - 0.03);
        }, 100);
      }});

      frameTriggers.push({ frame: 898, fired: false, callback: () => {
        if (scifiRef) { scifiRef.pause(); scifiRef.currentTime = 0; scifiRef = null; }
      }});

      function stopRenderAudio() {
        for (const a of audioQueue) { a.pause(); a.currentTime = 0; }
        audioQueue.length = 0;
        bootupRef = null;
        scifiRef = null;
      }

      let renderPlayer: ReturnType<typeof initRenderCanvas> | null = null;

      // Hook into tab switching for render start/stop
      tabs.forEach(tab => {
        tab.addEventListener('click', () => {
          const id = tab.dataset.tab;
          if (id === 'render') {
            if (!renderPlayer) renderPlayer = initRenderCanvas(renderCanvas, frameTriggers);
            renderPlayer.start();
          } else {
            renderPlayer?.stop();
            stopRenderAudio();
          }
        });
      });
    </script>
  </body>
</html>
