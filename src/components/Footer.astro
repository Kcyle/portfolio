---
const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer__inner">
    <p class="footer__copy">&copy; {currentYear} Kyle</p>
    <p class="footer__note">Built with Astro & GSAP</p>
  </div>
</footer>

<style>
  .footer {
    padding: 3rem var(--page-padding);
    border-top: 1px solid var(--color-border);
  }

  .footer__inner {
    max-width: var(--max-width);
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .footer__copy {
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--color-text-secondary);
  }

  .footer__note {
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  @media (max-width: 480px) {
    .footer__inner {
      flex-direction: column;
      gap: 0.5rem;
      text-align: center;
    }
  }
</style>
